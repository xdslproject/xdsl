{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":semanticCommitTypeAll(dependencies)",
    ":semanticCommitScopeDisabled"
  ],
  "labels": [
    "dependencies"
  ],
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "pre-commit": {
    "enabled": true
  },
  "nix": {
    "enabled": true
  },
  "rangeStrategy": "replace",
  "lockFileMaintenance": {
    "enabled": true
  }
}
